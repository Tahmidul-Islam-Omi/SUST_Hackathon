# Copy this file to .env and fill in real values locally.
# NEVER commit the real .env (it is gitignored).
# The service runs fully WITHOUT any LLM key — these are optional polish only.

# Toggle optional LLM drafting of agent_summary / customer_reply.
LLM_ENABLED=false

# Provider key (only if LLM_ENABLED=true). Names only here — no real values.
OPENAI_API_KEY=
MODEL_NAME=

# Port the service binds to (must bind 0.0.0.0 in deployment).
PORT=8000
